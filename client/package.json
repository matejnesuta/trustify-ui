{
  "name": "@trustify-ui/client",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "clean:all": "rimraf ./dist ./node_modules",
    "build": "npm run generate && vite build",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check --ignore-path ../.prettierignore './src/**/*.{ts,tsx,js,json}'",
    "format:fix": "prettier --write --ignore-path ../.prettierignore './src/**/*.{ts,tsx,js,json}'",
    "start:dev": "npm run generate && vite --port 3000 --host",
    "start": "vite preview",
    "test": "vitest --run",
    "generate": "openapi-ts -f ./config/openapi-ts.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^2.9.11",
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-log-viewer": "^6.3.0",
    "@patternfly/react-table": "^6.4.3",
    "@patternfly/react-tokens": "^6.4.0",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-query-devtools": "^5.61.0",
    "axios": "^1.16.0",
    "dayjs": "^1.11.18",
    "file-saver": "^2.0.5",
    "oidc-client-ts": "^3.3.0",
    "packageurl-js": "^2.0.1",
    "pretty-bytes": "^6.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "6.0.0",
    "react-hook-form": "^7.66.1",
    "react-markdown": "^8.0.7",
    "react-oidc-context": "^3.3.0",
    "react-router-dom": "^7.8.1",
    "tsd-ui": "github:tsd-ui/tsd-ui#v0.1.0",
    "usehooks-ts": "^3.1.1",
    "victory": "^37.3.4",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.2",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/file-saver": "^2.0.2",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.0.0",
    "vite": "^8.0.15",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "nyc": {},
  "msw": {
    "workerDirectory": "public"
  }
}
